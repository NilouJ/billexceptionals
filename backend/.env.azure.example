# ─────────────────────────────────────────────────────────────────────────────
# Outcome agent on Azure AI Foundry (Claude on Microsoft's hosting)
# Copy to backend/.env and fill in your Foundry deployment details.
#
# This uses Foundry's Anthropic-compatible passthrough endpoint
# (https://<resource>.services.ai.azure.com/anthropic/) via the standard
# Anthropic Python SDK with a custom base_url. No LiteLLM needed.
# ─────────────────────────────────────────────────────────────────────────────

LLM_PROVIDER=azure

# Foundry Anthropic-compatible endpoint — MUST end with /anthropic/
# Example: https://my-resource-eastus2.services.ai.azure.com/anthropic/
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/anthropic/

# Foundry API key (from the resource's Keys and Endpoint blade).
AZURE_AI_FOUNDRY_API_KEY=<your-key>

# The DEPLOYMENT NAME you gave the Claude model when you created it in Foundry.
# Example: claude-sonnet-4-6
AZURE_AI_FOUNDRY_DEPLOYMENT=<your-claude-deployment-name>
