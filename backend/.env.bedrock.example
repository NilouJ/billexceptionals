# ─────────────────────────────────────────────────────────────────────────────
# Outcome agent on AWS Bedrock (SP51 target platform)
# Copy to backend/.env and fill in your AWS access.
# ─────────────────────────────────────────────────────────────────────────────

LLM_PROVIDER=bedrock

# Model id — Claude Sonnet 4.5 inference profile (cross-region).
# If you get ResourceNotFoundException ("Legacy"), the model needs reactivation
# or a newer id. Check the FALLBACK badge in the UI for the live error.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Region to call Bedrock in. us-east-1 has the broadest model availability.
AWS_REGION=us-east-1

# AWS credentials — picked up from the standard chain (env vars, ~/.aws,
# instance profile). Easiest for hackathon: paste here, or run `aws configure`.
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
